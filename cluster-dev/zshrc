# ~/.zshrc — minimal, fast, friendly defaults for cluster-dev

# --- History --------------------------------------------------------------
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt INC_APPEND_HISTORY SHARE_HISTORY HIST_IGNORE_DUPS HIST_IGNORE_SPACE HIST_REDUCE_BLANKS

# --- Completion -----------------------------------------------------------
autoload -Uz compinit && compinit -u
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}' '+r:|[._-]=* r:|=*'
zstyle ':completion:*' list-colors ''
zstyle ':completion:*:descriptions' format '%F{yellow}-- %d --%f'

# --- Useful options -------------------------------------------------------
setopt AUTO_CD
setopt EXTENDED_GLOB
setopt INTERACTIVE_COMMENTS
setopt NO_BEEP
setopt PROMPT_SUBST

# Emacs key bindings (Ctrl-a / Ctrl-e / etc.)
bindkey -e

# --- Prompt (no external deps) -------------------------------------------
autoload -Uz colors && colors
autoload -Uz vcs_info
precmd() { vcs_info }
zstyle ':vcs_info:git:*' formats ' %F{yellow}(%b)%f'
PROMPT='%F{cyan}%n@%m%f %F{green}%~%f${vcs_info_msg_0_} %# '

# --- Aliases --------------------------------------------------------------
alias ll='ls -alh --color=auto'
alias la='ls -A   --color=auto'
alias l='ls  -CF  --color=auto'
alias grep='grep --color=auto'
alias ..='cd ..'
alias ...='cd ../..'

# --- Plugins (apt-installed) ----------------------------------------------
[[ -r /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]] \
  && source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
# syntax-highlighting must be sourced LAST
[[ -r /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] \
  && source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# --- Tool integrations ----------------------------------------------------
# uv shell completion (covers uv + uvx)
if command -v uv >/dev/null 2>&1; then
  eval "$(uv generate-shell-completion zsh 2>/dev/null)"
fi

# CUDA on PATH (already set by base image; reaffirm for safety)
export PATH="${CUDA_HOME:-/usr/local/cuda}/bin:${PATH}"

# Local user-installed binaries
export PATH="$HOME/.local/bin:$PATH"
